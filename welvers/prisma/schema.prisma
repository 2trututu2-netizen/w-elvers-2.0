generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tool {
  id           String   @id @default(cuid())
  locale       String
  slug         String   @unique
  title        String
  excerpt      String
  category     String
  pricing      String
  affiliateUrl String?
  content      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
